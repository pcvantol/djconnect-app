{
  "info": {
    "_postman_id": "79fa7eb1-9c9f-4f2c-8d8a-djconnect-local-api",
    "name": "DJConnect Local Client API",
    "description": "Local iOS/macOS Client API endpoints hosted by the DJConnect app for Home Assistant pairing and app callbacks. Import this collection and set client_api_url to the URL shown by the app.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "client_api_url",
      "value": "http://192.168.1.104:60955",
      "type": "string"
    },
    {
      "key": "pair_code",
      "value": "123456",
      "type": "string"
    },
    {
      "key": "device_id",
      "value": "djconnect-ios-XXXXXXXXXXXX",
      "type": "string"
    },
    {
      "key": "client_type",
      "value": "ios",
      "type": "string"
    },
    {
      "key": "device_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "ha_local_url",
      "value": "http://homeassistant.local:8123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Pairing Info",
      "item": [
        {
          "name": "GET /api/device/pairing-info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{client_api_url}}/api/device/pairing-info",
              "host": ["{{client_api_url}}"],
              "path": ["api", "device", "pairing-info"]
            },
            "description": "Returns device_id, client_type, app version, local URL and the current pair_code shown in the app."
          },
          "response": []
        },
        {
          "name": "GET /api/device/info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{client_api_url}}/api/device/info",
              "host": ["{{client_api_url}}"],
              "path": ["api", "device", "info"]
            },
            "description": "Returns the same local device metadata without exposing the current pair code."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pairing Callback",
      "item": [
        {
          "name": "POST /api/device/pair",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pair_code\": \"{{pair_code}}\",\n  \"device_id\": \"{{device_id}}\",\n  \"device_name\": \"DJConnect iPhone\",\n  \"client_type\": \"{{client_type}}\",\n  \"device_token\": \"{{device_token}}\",\n  \"ha_local_url\": \"{{ha_local_url}}\",\n  \"assist_pipeline_id\": \"\"\n}"
            },
            "url": {
              "raw": "{{client_api_url}}/api/device/pair",
              "host": ["{{client_api_url}}"],
              "path": ["api", "device", "pair"]
            },
            "description": "Simulates the Home Assistant pairing callback. device_token is intentionally a variable and should not be committed with a real value."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authenticated HA Callbacks",
      "item": [
        {
          "name": "POST /api/device/command",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{device_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"command\": \"settings\",\n  \"language\": \"nl\",\n  \"log_level\": \"info\"\n}"
            },
            "url": {
              "raw": "{{client_api_url}}/api/device/command",
              "host": ["{{client_api_url}}"],
              "path": ["api", "device", "command"]
            },
            "description": "Home Assistant to app command callback. Requires the bearer device_token from pairing."
          },
          "response": []
        },
        {
          "name": "POST /api/device/dj_response",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{device_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Ja ja, daar is hij dan.\",\n  \"audio_url\": \"\",\n  \"audio_type\": \"\"\n}"
            },
            "url": {
              "raw": "{{client_api_url}}/api/device/dj_response",
              "host": ["{{client_api_url}}"],
              "path": ["api", "device", "dj_response"]
            },
            "description": "Home Assistant callback that sends the DJ response text and optional audio URL to the app."
          },
          "response": []
        },
        {
          "name": "POST /api/device/forget",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{device_token}}"
              }
            ],
            "url": {
              "raw": "{{client_api_url}}/api/device/forget",
              "host": ["{{client_api_url}}"],
              "path": ["api", "device", "forget"]
            },
            "description": "Home Assistant callback for clearing the local app pairing. Requires the bearer device_token."
          },
          "response": []
        }
      ]
    }
  ]
}
