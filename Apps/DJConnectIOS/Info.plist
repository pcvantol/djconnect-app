<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>DJConnect</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>dev.djconnect.ios</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>djconnect</string>
			</array>
		</dict>
	</array>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.music</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoadsInLocalNetworking</key>
		<true/>
	</dict>
	<key>NSBonjourServices</key>
	<array>
		<string>_home-assistant._tcp.</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>DJConnect gebruikt de camera alleen om de koppel-QR-code van Home Assistant of Apple Watch te scannen.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>DJConnect maakt verbinding met Home Assistant op je lokale netwerk.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>DJConnect neemt je stem op voor push-to-talk muziekverzoeken aan Home Assistant.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>DJConnect gebruikt spraakherkenning om de wake-zin te herkennen.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIApplicationShortcutItems</key>
	<array>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>music.note</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Speelt Nu</string>
			<key>UIApplicationShortcutItemType</key>
			<string>dev.djconnect.action.now-playing</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>bubble.left.and.bubble.right.fill</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Ask DJ</string>
			<key>UIApplicationShortcutItemType</key>
			<string>dev.djconnect.action.ask-dj</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>waveform.path.ecg</string>
			<key>UIApplicationShortcutItemSubtitle</key>
			<string>Analyseer huidig nummer</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Track Insight</string>
			<key>UIApplicationShortcutItemType</key>
			<string>dev.djconnect.action.track-insight</string>
		</dict>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>wifi</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
