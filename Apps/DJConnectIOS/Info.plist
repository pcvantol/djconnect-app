<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>DJConnect</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>dev.djconnect.ios</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>djconnect</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.music</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoadsInLocalNetworking</key>
		<true/>
	</dict>
	<key>NSBonjourServices</key>
	<array>
		<string>_home-assistant._tcp.</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>DJConnect uses the camera only to scan the pairing QR code from Home Assistant or Apple Watch.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>DJConnect connects to Home Assistant on your local network.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>DJConnect records your voice for push-to-talk music requests to Home Assistant.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>DJConnect uses speech recognition to detect the wake phrase.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIApplicationShortcutItems</key>
	<array>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>music.note</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Now Playing</string>
			<key>UIApplicationShortcutItemType</key>
			<string>dev.djconnect.action.now-playing</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>bubble.left.and.bubble.right</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Ask DJ</string>
			<key>UIApplicationShortcutItemType</key>
			<string>dev.djconnect.action.ask-dj</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>waveform.path.ecg</string>
			<key>UIApplicationShortcutItemSubtitle</key>
			<string>Analyze current track</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Track Insight</string>
			<key>UIApplicationShortcutItemType</key>
			<string>dev.djconnect.action.track-insight</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>sparkles</string>
			<key>UIApplicationShortcutItemSubtitle</key>
			<string>Music DNA recommendations</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Discover</string>
			<key>UIApplicationShortcutItemType</key>
			<string>dev.djconnect.action.discovery</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>music.note.list</string>
			<key>UIApplicationShortcutItemSubtitle</key>
			<string>Upcoming tracks</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Queue</string>
			<key>UIApplicationShortcutItemType</key>
			<string>dev.djconnect.action.queue</string>
		</dict>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>wifi</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
