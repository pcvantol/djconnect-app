                                    <constraint firstItem="launch-banner" firstAttribute="centerY" secondItem="hero-panel" secondAttribute="centerY" constant="-30" id="launch-banner-center-y"/>
                                    <constraint firstItem="launch-spinner" firstAttribute="centerX" secondItem="hero-panel" secondAttribute="centerX" id="launch-spinner-center-x"/>
                                    <constraint firstItem="launch-spinner" firstAttribute="top" secondItem="launch-banner" secondAttribute="bottom" constant="28" id="launch-spinner-top"/>
