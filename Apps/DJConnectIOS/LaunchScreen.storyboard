                                    <constraint firstItem="launch-icon" firstAttribute="centerY" secondItem="hero-panel" secondAttribute="centerY" constant="-175" id="launch-icon-center-y"/>
                                    <constraint firstItem="launch-title" firstAttribute="top" secondItem="launch-icon" secondAttribute="bottom" constant="28" id="launch-title-top"/>
                                    <constraint firstItem="launch-title" firstAttribute="leading" secondItem="hero-panel" secondAttribute="leading" constant="40" id="launch-title-leading"/>
                                    <constraint firstAttribute="trailing" secondItem="launch-title" secondAttribute="trailing" constant="40" id="launch-title-trailing"/>
                                    <constraint firstItem="launch-tagline" firstAttribute="top" secondItem="launch-title" secondAttribute="bottom" constant="12" id="launch-tagline-top"/>
                                    <constraint firstItem="launch-tagline" firstAttribute="leading" secondItem="hero-panel" secondAttribute="leading" constant="40" id="launch-tagline-leading"/>
                                    <constraint firstAttribute="trailing" secondItem="launch-tagline" secondAttribute="trailing" constant="40" id="launch-tagline-trailing"/>
                                    <constraint firstItem="launch-spinner" firstAttribute="centerX" secondItem="hero-panel" secondAttribute="centerX" id="launch-spinner-center-x"/>
